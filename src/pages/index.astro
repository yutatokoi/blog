  className="flex min-h-svh max-w-lg flex-col justify-center"
>
  <main class="space-y-4">
    <article>
    <h3>Yuta Tokoi</h3>
    <p>I'm interested in making software secure and reliable.
    <hr />
    <h3>Links</h3>
    <ul class="flex flex-col gap-1.5">
      <SocialLink url="https://github.com/yutatokoi" name="GitHub" />
      <SocialLink url="https://x.com/yutatokoi/" name="X" />
      <SocialLink url="https://www.linkedin.com/in/yuta-tokoi/" name="LinkedIn" />
      <li>Email: yutatokoi [at] proton.me</li>
    </ul>
    </article>
  </main>
</Layout>

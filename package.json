{
  "name": "miniblog",
  "type": "module",
  "version": "0.0.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "file:vendor/astrojs-check-0.9.7.tgz",
    "@astrojs/sitemap": "file:vendor/astrojs-sitemap-3.7.1.tgz",
    "@tailwindcss/postcss": "file:vendor/tailwindcss-postcss-4.2.1.tgz",
    "@tailwindcss/vite": "file:vendor/tailwindcss-vite-4.2.1.tgz",
    "astro": "file:vendor/astro-6.0.4.tgz",
    "tailwind-merge": "file:vendor/tailwind-merge-3.5.0.tgz",
    "tailwindcss": "file:vendor/tailwindcss-4.2.1.tgz",
    "typescript": "file:vendor/typescript-5.9.3.tgz"
  },
  "devDependencies": {
    "prettier": "file:vendor/prettier-3.8.1.tgz",
    "prettier-plugin-astro": "file:vendor/prettier-plugin-astro-0.14.1.tgz",
    "prettier-plugin-astro-organize-imports": "file:vendor/prettier-plugin-astro-organize-imports-0.4.11.tgz",
    "prettier-plugin-tailwindcss": "file:vendor/prettier-plugin-tailwindcss-0.7.2.tgz"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
